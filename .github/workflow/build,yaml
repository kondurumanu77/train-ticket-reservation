name: CI/CD Pipeline for Java WAR Deployment

on:
  workflow_dispatch:
    inputs:
      environment:
        description: "Select Deployment Environment"
        required: true
        type: choice
        options:
          - dev
          - test
          - pre-prod
          - prod

jobs:
  build-and-deploy:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout Source Code
        uses: actions/checkout@v4

      - name: Setup Java 17
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: '17'
          cache: maven

      - name: Build Application
        run: mvn clean package

      - name: Verify WAR File
        run: |
          echo "Contents of target directory:"
          ls -lh target
          WAR_FILE=$(find target -name "*.war" | head -1)

          if [ -z "$WAR_FILE" ]; then
            echo "WAR file not found!"
            exit 1
          fi

          echo "WAR_FILE=$WAR_FILE" >> $GITHUB_ENV
          echo "WAR File: $WAR_FILE"

      - name: Deploy to DEV
        if: github.event.inputs.environment == 'dev'
        run: |
          curl --fail -v \
            -u "${{ secrets.DEV_USER }}:${{ secrets.DEV_PASSWORD }}" \
            -T "$WAR_FILE" \
            "http://${{ secrets.DEV_HOST }}:8080/manager/text/deploy?path=/TrainBook&update=true"

      - name: Deploy to TEST
        if: github.event.inputs.environment == 'test'
        run: |
          curl --fail -v \
            -u "${{ secrets.TEST_USER }}:${{ secrets.TEST_PASSWORD }}" \
            -T "$WAR_FILE" \
            "http://${{ secrets.TEST_HOST }}:8080/manager/text/deploy?path=/TrainBook&update=true"

      - name: Deploy to PRE-PROD
        if: github.event.inputs.environment == 'pre-prod'
        run: |
          curl --fail -v \
            -u "${{ secrets.PREPROD_USER }}:${{ secrets.PREPROD_PASSWORD }}" \
            -T "$WAR_FILE" \
            "http://${{ secrets.PREPROD_HOST }}:8080/manager/text/deploy?path=/TrainBook&update=true"

      - name: Deploy to PROD
        if: github.event.inputs.environment == 'prod'
        run: |
          curl --fail -v \
            -u "${{ secrets.PROD_USER }}:${{ secrets.PROD_PASSWORD }}" \
            -T "$WAR_FILE" \
            "http://${{ secrets.PROD_HOST }}:8080/manager/text/deploy?path=/TrainBook&update=true"
